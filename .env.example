# =============================================================================
# Birthday Bot — environment configuration
# Copy this file to `.env` for local runs. On Railway, set these as secrets.
# Never commit the real .env to git.
# =============================================================================

# --- Telegram ---
# From @BotFather after `/newbot`
TELEGRAM_BOT_TOKEN=123456:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Your personal Telegram chat_id (DM target for approval requests).
# Find with: python -m tools.get_my_chat_id
OWNER_CHAT_ID=123456789

# The team group chat_id where approved wishes get posted.
# Find with: python -m tools.get_group_id
GROUP_CHAT_ID=-1001234567890

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Google Sheets ---
# The sheet's ID is the long string in the URL between /d/ and /edit
GOOGLE_SHEET_ID=1AbCdEfGhIjKlMnOpQrStUvWxYz0123456789
# Worksheet/tab name within the spreadsheet
GOOGLE_SHEET_TAB=Team

# Service account JSON — paste the full JSON content as a single line, escaped.
# On Railway: paste raw multiline JSON into the secret field; Railway preserves it.
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# --- Schedule ---
TIMEZONE=Europe/Moscow
SEND_TIME=10:00

# --- Misc ---
# When true, skips actual posting to group; logs what *would* have been sent.
# Approval flow still works (you'll see the DM), but the "✅ Опубликовать" button
# only logs and doesn't post. Useful for first-run validation.
DRY_RUN=false

# Path for the SQLite state file. On Railway, point this at a mounted volume
# (e.g. /data/state.db) so pending drafts survive restarts.
DB_PATH=./state.db

# Logging level: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
